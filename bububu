    // ==========================================
    // 4-A. PHYSICS PENDULUM SIMULATOR
    // ==========================================
    let physAnimFrame = null;
    let physLength = 150;
    let physGravity = 9.8;
    let physDamping = 0.01;
    let physMass = 15;

    let physState = {
      angle: Math.PI / 4,
      angularVelocity: 0,
      angularAcceleration: 0,
      isDragging: false
    };

    function initPhysicsSimulator() {
      const canvas = document.getElementById('physics-canvas');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');

      const resizeCanvas = () => {
        canvas.width = canvas.parentElement.clientWidth;
        canvas.height = 360;
      };
      
      resizeCanvas();
      window.addEventListener('resize', resizeCanvas);

      const originX = () => canvas.width / 2;
      const originY = 50;

      // Mouse/Touch drag utility
      const getCoords = (e) => {
        const rect = canvas.getBoundingClientRect();
        const clientX = e.touches ? e.touches[0].clientX : e.clientX;
        const clientY = e.touches ? e.touches[0].clientY : e.clientY;
        return {
          x: clientX - rect.left,
          y: clientY - rect.top
        };
      };

      const onDown = (e) => {
        const coords = getCoords(e);
        const bobX = originX() + physLength * Math.sin(physState.angle);
        const bobY = originY + physLength * Math.cos(physState.angle);
        const dist = Math.sqrt((coords.x - bobX) ** 2 + (coords.y - bobY) ** 2);
        const bobRadius = 10 + physMass * 0.5;

        if (dist < bobRadius + 15) {
          physState.isDragging = true;
          physState.angularVelocity = 0;
        }
      };

      const onMove = (e) => {
        if (!physState.isDragging) return;
        const coords = getCoords(e);
        const dx = coords.x - originX();
        const dy = coords.y - originY;
        physState.angle = Math.atan2(dx, dy);
      };

      const onUp = () => {
        physState.isDragging = false;
      };

      canvas.addEventListener('mousedown', onDown);
      canvas.addEventListener('mousemove', onMove);
      canvas.addEventListener('mouseup', onUp);
      canvas.addEventListener('mouseleave', onUp);

      canvas.addEventListener('touchstart', onDown);
      canvas.addEventListener('touchmove', onMove);
      canvas.addEventListener('touchend', onUp);

      const loop = () => {
        if (!physState.isDragging) {
          // Equation: theta'' = - (g / L) * sin(theta) - damping * theta'
          const gTerm = -(physGravity / physLength) * Math.sin(physState.angle);
          physState.angularAcceleration = gTerm - (physDamping * physState.angularVelocity);
          physState.angularVelocity += physState.angularAcceleration;
          physState.angle += physState.angularVelocity;
        }

        ctx.clearRect(0, 0, canvas.width, canvas.height);

        // Center line
        ctx.strokeStyle = '#33415550';
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.moveTo(originX(), 0);
        ctx.lineTo(originX(), canvas.height);
        ctx.stroke();

        // Wire
        const bobX = originX() + physLength * Math.sin(physState.angle);
        const bobY = originY + physLength * Math.cos(physState.angle);

        ctx.strokeStyle = '#818CF8';
        ctx.lineWidth = 3;
        ctx.beginPath();
        ctx.moveTo(originX(), originY);
        ctx.lineTo(bobX, bobY);
        ctx.stroke();

        // Top Pivot
        ctx.fillStyle = '#475569';
        ctx.beginPath();
        ctx.arc(originX(), originY, 6, 0, 2 * Math.PI);
        ctx.fill();

        // Mass Bob
        const bobRadius = 10 + physMass * 0.5;
        ctx.fillStyle = '#E11D48';
        ctx.beginPath();
        ctx.arc(bobX, bobY, bobRadius, 0, 2 * Math.PI);
        ctx.fill();
        ctx.strokeStyle = '#FFFFFF';
        ctx.lineWidth = 2;
        ctx.stroke();

        // Energy Calculations
        const h = physLength * (1 - Math.cos(physState.angle));
        const potentialEnergy = physMass * (physGravity / 10) * h;
        const v = physLength * physState.angularVelocity;
        const kineticEnergy = 0.5 * physMass * (v * v) * 0.001;
        const totalEnergy = potentialEnergy + kineticEnergy;

        // UI texts
        ctx.fillStyle = '#94A3B8';
        ctx.font = 'bold 11px Courier New';
        ctx.fillText(`각도 (Angle): ${(physState.angle * (180 / Math.PI)).toFixed(1)}°`, 15, 30);
        ctx.fillText(`주기 (T): ${(2 * Math.PI * Math.sqrt(physLength / (physGravity * 10))).toFixed(2)}s (이론값)`, 15, 48);

        // Bars
        const graphX = canvas.width - 200;
        const maxBarWidth = 160;

        ctx.fillStyle = '#64748B';
        ctx.fillText('위치에너지 (PE)', graphX, 25);
        ctx.fillStyle = '#3B82F6';
        ctx.fillRect(graphX, 30, Math.min(potentialEnergy * 1.5, maxBarWidth), 10);

        ctx.fillStyle = '#64748B';
        ctx.fillText('운동에너지 (KE)', graphX, 55);
        ctx.fillStyle = '#EF4444';
        ctx.fillRect(graphX, 60, Math.min(kineticEnergy * 1.5, maxBarWidth), 10);

        ctx.fillStyle = '#64748B';
        ctx.fillText('총 역학에너지 (E)', graphX, 85);
        ctx.fillStyle = '#10B981';
        ctx.fillRect(graphX, 90, Math.min(totalEnergy * 1.5, maxBarWidth), 10);

        physAnimFrame = requestAnimationFrame(loop);
      };

      if (physAnimFrame) cancelAnimationFrame(physAnimFrame);
      loop();
    }

    function stopPhysicsSimulator() {
      if (physAnimFrame) {
        cancelAnimationFrame(physAnimFrame);
        physAnimFrame = null;
      }
    }

    // Connect slider listeners
    document.getElementById('slider-len').addEventListener('input', (e) => {
      physLength = Number(e.target.value);
      document.getElementById('label-len').textContent = `${physLength}px`;
    });

    document.getElementById('slider-g').addEventListener('input', (e) => {
      physGravity = Number(e.target.value);
      document.getElementById('label-g').textContent = `${physGravity.toFixed(1)} m/s²`;
    });

    document.getElementById('slider-mass').addEventListener('input', (e) => {
      physMass = Number(e.target.value);
      document.getElementById('label-mass').textContent = `${physMass}kg`;
    });

    document.getElementById('slider-damping').addEventListener('input', (e) => {
      physDamping = Number(e.target.value);
      document.getElementById('label-damping').textContent = physDamping.toFixed(3);
    });

    function setGravityPreset(val) {
      physGravity = val;
      document.getElementById('slider-g').value = val;
      document.getElementById('label-g').textContent = `${val.toFixed(1)} m/s²`;
    }


    // ==========================================
    // 4-B. SORTING ALGORITHM VISUALIZER
    // ==========================================
    let sortArray = [];
    let sortSize = 24;
    let sortSpeed = 70;
    let isSorting = false;
    let activeIndices = [];
    let completedIndices = [];

    function resetSortArray() {
      if (isSorting) return;
      sortArray = [];
      for (let i = 0; i < sortSize; i++) {
        sortArray.push(Math.floor(Math.random() * 160) + 20);
      }
      activeIndices = [];
      completedIndices = [];
      renderSortArray();
    }

    function renderSortArray() {
      const container = document.getElementById('sort-bars-workspace');
      container.innerHTML = sortArray.map((val, idx) => {
        let barColor = 'bg-indigo-500/80';
        if (activeIndices.includes(idx)) {
          barColor = 'bg-rose-500 animate-pulse';
        } else if (completedIndices.includes(idx)) {
          barColor = 'bg-emerald-500/80';
        }

        const width = Math.max(12, Math.min(30, 480 / sortSize));
        return `
          <div class="rounded-t transition-all ${barColor}" style="height: ${val}px; width: ${width}px;" title="값: ${val}"></div>
        `;
      }).join('');
    }

    const sleep = (ms) => new Promise(resolve => setTimeout(resolve, ms));

    async function runBubbleSort() {
      if (isSorting) return;
      isSorting = true;
      disableSortingInputs(true);

      const arr = [...sortArray];
      const len = arr.length;
      let localSorted = [];

      for (let i = 0; i < len; i++) {
        for (let j = 0; j < len - i - 1; j++) {
          activeIndices = [j, j + 1];
          renderSortArray();
          await sleep(105 - sortSpeed);

          if (arr[j] > arr[j + 1]) {
            const temp = arr[j];
            arr[j] = arr[j + 1];
            arr[j + 1] = temp;
            sortArray[j] = arr[j];
            sortArray[j + 1] = arr[j + 1];
            renderSortArray();
          }
        }
        localSorted.push(len - i - 1);
        completedIndices = [...localSorted];
      }

      activeIndices = [];
      renderSortArray();
      isSorting = false;
      disableSortingInputs(false);
    }

    async function runInsertionSort() {
      if (isSorting) return;
      isSorting = true;
      disableSortingInputs(true);

      const arr = [...sortArray];
      const len = arr.length;

      for (let i = 1; i < len; i++) {
        let key = arr[i];
        let j = i - 1;
        activeIndices = [i, j];
        renderSortArray();
        await sleep(105 - sortSpeed);

        while (j >= 0 && arr[j] > key) {
          arr[j + 1] = arr[j];
          sortArray[j + 1] = arr[j];
          j = j - 1;
          renderSortArray();
          activeIndices = [j + 1, i];
          await sleep(105 - sortSpeed);
        }
        arr[j + 1] = key;
        sortArray[j + 1] = key;
        renderSortArray();
      }

      completedIndices = Array.from({ length: len }, (_, k) => k);
      activeIndices = [];
      renderSortArray();
      isSorting = false;
      disableSortingInputs(false);
    }

    function disableSortingInputs(disabled) {
      document.getElementById('sort-btn-reset').disabled = disabled;
      document.getElementById('sort-btn-bubble').disabled = disabled;
      document.getElementById('sort-btn-insert').disabled = disabled;
      document.getElementById('slider-sort-speed').disabled = disabled;
      document.getElementById('slider-sort-size').disabled = disabled;
    }

    document.getElementById('slider-sort-speed').addEventListener('input', (e) => {
      sortSpeed = Number(e.target.value);
      document.getElementById('label-sort-speed').textContent = sortSpeed;
    });

    document.getElementById('slider-sort-size').addEventListener('input', (e) => {
      sortSize = Number(e.target.value);
      document.getElementById('label-sort-size').textContent = sortSize;
      resetSortArray();
    });

    // Window load triggers
    window.addEventListener('load', () => {
      setPomoMode('study');
      resetSortArray();
    });
  </script>
</body>
