  <!-- CORE SCRIPT LOGIC (VANILLA JS + WEB AUDIO + CANVAS + GEMINI API) -->
  <script>
    // Global API Configuration
    const apiKey = ""; // Runtime automatically injected by the environment

    // Tab switcher helper
    function switchTab(tabId) {
