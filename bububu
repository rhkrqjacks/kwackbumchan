<!DOCTYPE html>
<html lang="ko" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Smart Study Simulator</title>
  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Google Fonts: Inter & JetBrains Mono -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Inter', sans-serif;
    }
    .font-mono {
      font-family: 'JetBrains Mono', monospace;
    }
    /* Custom scrollbar */
    ::-webkit-scrollbar {
      width: 6px;
      height: 6px;
    }
    ::-webkit-scrollbar-track {
      background: #0f172a;
    }
    ::-webkit-scrollbar-thumb {
      background: #334155;
      border-radius: 4px;
    }
    ::-webkit-scrollbar-thumb:hover {
      background: #475569;
    }
  </style>
</head>
<body class="bg-slate-900 text-slate-100 flex flex-col min-h-screen selection:bg-indigo-500 selection:text-white">

  <!-- NAVIGATION HEADER -->
  <header class="border-b border-slate-800 bg-slate-900/95 backdrop-blur sticky top-0 z-50 px-6 py-4 flex flex-col md:flex-row justify-between items-center gap-4">
    <div class="flex items-center gap-3">
      <div class="bg-indigo-600 p-2.5 rounded-xl shadow-lg shadow-indigo-500/20 text-white animate-pulse">
        <!-- Brain Icon -->
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.44 2.5 2.5 0 0 1 0-3.12 3 3 0 0 1 0-4.88 2.5 2.5 0 0 1 0-3.12A2.5 2.5 0 0 1 9.5 2Z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96-.44 2.5 2.5 0 0 0 0-3.12 3 3 0 0 0 0-4.88 2.5 2.5 0 0 0 0-3.12A2.5 2.5 0 0 0 14.5 2Z"/></svg>
      </div>
      <div>
        <h1 class="text-xl font-extrabold tracking-tight bg-gradient-to-r from-indigo-400 via-purple-400 to-pink-400 bg-clip-text text-transparent">
          Smart Study Simulator
        </h1>
        <p class="text-xs text-slate-400">집중력 강화, 메타인지 메이커 & 개념 인터랙티브 학습 공간</p>
      </div>
    </div>

    <!-- Global Tab Switch Navigation -->
    <nav class="flex flex-wrap bg-slate-950 p-1 rounded-xl border border-slate-800/80">
      <button onclick="switchTab('pomodoro')" id="tab-btn-pomodoro" class="tab-btn flex items-center gap-2 px-4 py-2 text-sm font-semibold rounded-lg transition-all bg-indigo-600 text-white shadow-md">
        <!-- Timer Icon -->
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span>포커스 타이머</span>
      </button>
      <button onclick="switchTab('feynman')" id="tab-btn-feynman" class="tab-btn flex items-center gap-2 px-4 py-2 text-sm font-semibold rounded-lg transition-all text-slate-400 hover:text-slate-200">
        <!-- Lightbulb Icon -->
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .6 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>
        <span>소크라테스 AI 튜터</span>
      </button>
      <button onclick="switchTab('quiz')" id="tab-btn-quiz" class="tab-btn flex items-center gap-2 px-4 py-2 text-sm font-semibold rounded-lg transition-all text-slate-400 hover:text-slate-200">
        <!-- GraduationCap Icon -->
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"/></svg>
        <span>AI 맞춤 퀴즈</span>
      </button>
      <button onclick="switchTab('simulators')" id="tab-btn-simulators" class="tab-btn flex items-center gap-2 px-4 py-2 text-sm font-semibold rounded-lg transition-all text-slate-400 hover:text-slate-200">
        <!-- Activity Icon -->
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        <span>개념 시뮬레이터</span>
      </button>
    </nav>
  </header>

  <!-- MAIN MAIN CONTAINER -->
  <main class="flex-1 max-w-7xl w-full mx-auto p-4 md:p-6 lg:p-8 flex flex-col gap-6">

    <!-- 1. POMODORO SECTION -->
    <section id="section-pomodoro" class="tab-content grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Timer Main Controller -->
      <div class="lg:col-span-2 bg-slate-800/50 border border-slate-700/60 rounded-2xl p-6 flex flex-col items-center justify-between min-h-[480px] shadow-xl">
        <div class="w-full flex justify-between items-center mb-4">
          <span id="pomo-mode-badge" class="px-4 py-1.5 rounded-full text-xs font-bold border tracking-wider uppercase border-rose-500 text-rose-400 bg-rose-500/10">
            집중 시간 🎯
          </span>
          <div class="flex gap-1.5">
            <button onclick="setPomoMode('study')" id="pomo-btn-study" class="pomo-mode-btn px-3 py-1 text-xs font-bold rounded-lg transition-colors bg-indigo-600 text-white">공부</button>
            <button onclick="setPomoMode('shortBreak')" id="pomo-btn-shortBreak" class="pomo-mode-btn px-3 py-1 text-xs font-bold rounded-lg transition-colors bg-slate-900 text-slate-400 hover:text-slate-200">짧은휴식</button>
            <button onclick="setPomoMode('longBreak')" id="pomo-btn-longBreak" class="pomo-mode-btn px-3 py-1 text-xs font-bold rounded-lg transition-colors bg-slate-900 text-slate-400 hover:text-slate-200">긴휴식</button>
          </div>
        </div>

        <!-- Timer Circle -->
        <div class="relative w-64 h-64 flex items-center justify-center my-6">
          <svg class="w-full h-full transform -rotate-90">
            <circle cx="128" cy="128" r="110" stroke="currentColor" stroke-width="10" class="text-slate-700/40" fill="transparent"/>
            <circle id="pomo-progress-circle" cx="128" cy="128" r="110" stroke="currentColor" stroke-width="10" class="transition-all duration-300 text-rose-500" fill="transparent" stroke-dasharray="691.15" stroke-dashoffset="0"/>
          </svg>
          <div class="absolute inset-0 flex flex-col items-center justify-center">
            <span id="pomo-time-display" class="text-5xl font-mono font-extrabold tracking-tight">25:00</span>
            <span id="pomo-status-sub" class="text-xs text-slate-400 mt-1 uppercase tracking-widest">대기 중</span>
          </div>
        </div>

        <!-- Action Controls -->
        <div class="flex items-center gap-4 w-full justify-center">
          <button onclick="resetPomoTimer()" class="p-3.5 bg-slate-700/60 hover:bg-slate-600 rounded-xl transition text-slate-300" title="초기화">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><polyline points="3 3 3 8 8 8"/></svg>
          </button>
          <button onclick="togglePomoTimer()" id="pomo-play-btn" class="px-8 py-3.5 rounded-xl font-bold flex items-center gap-2.5 shadow-lg transition-transform active:scale-95 bg-indigo-600 hover:bg-indigo-500 shadow-indigo-600/15 text-white">
            <svg id="pomo-play-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            <span id="pomo-play-text">집중 시작</span>
          </button>
        </div>
      </div>

      <!-- Sounds & Notes Sidebar -->
      <div class="flex flex-col gap-6">
        <!-- Soundscapes Console -->
        <div class="bg-slate-800/50 border border-slate-700/60 rounded-2xl p-5 shadow-lg">
          <h3 class="text-sm font-bold text-slate-300 uppercase tracking-widest mb-3 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
            집중 강화 사운드 테라피
          </h3>
          <p class="text-xs text-slate-400 mb-4">
            Web Audio API로 직접 합성하여 오프라인에서도 작동하는 초집중 소음 필터입니다.
          </p>

          <div class="grid grid-cols-3 gap-2">
            <button onclick="setFocusSound('none')" id="sound-btn-none" class="sound-toggle-btn p-3 rounded-xl border text-xs font-semibold flex flex-col items-center gap-2 transition-all border-indigo-500 bg-indigo-500/10 text-indigo-400">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
              <span>소리 없음</span>
            </button>
            <button onclick="setFocusSound('white')" id="sound-btn-white" class="sound-toggle-btn p-3 rounded-xl border text-xs font-semibold flex flex-col items-center gap-2 transition-all border-slate-700 bg-slate-900/60 text-slate-400 hover:border-slate-600">
              <span class="text-lg">🌧️</span>
              <span>집중 빗소리</span>
            </button>
            <button onclick="setFocusSound('binaural')" id="sound-btn-binaural" class="sound-toggle-btn p-3 rounded-xl border text-xs font-semibold flex flex-col items-center gap-2 transition-all border-slate-700 bg-slate-900/60 text-slate-400 hover:border-slate-600">
              <span class="text-lg">🎧</span>
              <span>14Hz 알파파</span>
            </button>
          </div>
        </div>

        <!-- Task Planner & Logs -->
        <div class="bg-slate-800/50 border border-slate-700/60 rounded-2xl p-5 flex-1 shadow-lg flex flex-col">
          <h3 class="text-sm font-bold text-slate-300 mb-3 tracking-wide">현재 세션의 학습 목표</h3>
          <input type="text" id="pomo-target-input" placeholder="예: 물리학 역학 파트 인강 1개 수강하기" class="w-full bg-slate-900 border border-slate-700 rounded-xl px-4 py-2.5 text-sm text-slate-200 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition"/>

          <div class="mt-5 flex-1 flex flex-col">
            <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">오늘 달성한 학습 내역</h4>
            <div id="pomo-logs-container" class="flex-1 overflow-y-auto max-h-[160px] bg-slate-900/50 border border-slate-800 rounded-xl p-3 text-xs space-y-2.5">
              <div class="h-full flex items-center justify-center text-slate-500 italic py-6">
                오늘 집중한 세션이 아직 없습니다. 파이팅!
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 2. SOCRATES FEYNMAN AI SECTION -->
    <section id="section-feynman" class="tab-content hidden bg-slate-800/40 border border-slate-700/60 rounded-2xl p-6 shadow-xl flex flex-col md:min-h-[600px]">
      <div class="flex flex-col md:flex-row md:items-center justify-between border-b border-slate-700/60 pb-4 mb-4 gap-4">
        <div>
          <h2 class="text-lg font-bold text-indigo-400 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .6 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>
            소크라테스식 AI 메타인지 튜터
          </h2>
          <p class="text-xs text-slate-400">
            개념을 직접 설명하며 배우는 최고의 학습법인 '파인만 학습법' 기반의 대화형 공부방입니다.
          </p>
        </div>
        <button id="feynman-reset-btn" onclick="resetFeynmanSession()" class="hidden px-4 py-2 bg-slate-700 hover:bg-slate-600 rounded-lg text-xs font-bold transition text-slate-200">
          주제 재설정
        </button>
      </div>

      <!-- Feynman Setup State -->
      <div id="feynman-setup" class="max-w-xl mx-auto w-full my-auto py-8 text-center flex flex-col items-center">
        <div class="w-16 h-16 bg-indigo-500/10 border border-indigo-500/20 rounded-2xl flex items-center justify-center text-indigo-400 mb-5 animate-bounce">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .6 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>
        </div>
        <h3 class="text-xl font-bold mb-2 text-slate-200">무엇을 제대로 공부하고 싶나요?</h3>
        <p class="text-sm text-slate-400 mb-6 leading-relaxed">
          배우고 있는 어려운 물리 법칙, 수학 정리, 생물학 현상, 심지어 역사 사건까지 알려주세요.<br />
          AI가 꼬리 질문을 던지며 당신의 논리에 빈틈이 없는지 스스로 점검하게 도와줍니다.
        </p>

        <div class="flex flex-col sm:flex-row gap-2.5 w-full">
          <input type="text" id="feynman-topic-input" placeholder="예: 슈뢰딩거 고양이, 한계효용 체감 법칙, 미적분 기본정리..." class="flex-1 bg-slate-900 border border-slate-700 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 text-slate-100"/>
          <button onclick="startFeynmanSession()" id="feynman-start-btn" class="px-6 py-3 bg-indigo-600 hover:bg-indigo-500 disabled:opacity-50 text-white rounded-xl font-bold transition shadow-lg shadow-indigo-600/15 text-sm shrink-0">
            튜터링 시작
          </button>
        </div>
      </div>

      <!-- Feynman Chat Active State -->
      <div id="feynman-chat-area" class="hidden flex-1 flex flex-col h-[500px]">
        <div class="text-center mb-3">
          <span id="feynman-active-topic" class="inline-block px-3 py-1 bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 rounded-full text-[11px] font-bold">
            공부 주제: 
          </span>
        </div>

        <div id="feynman-messages" class="flex-1 overflow-y-auto mb-4 p-4 rounded-xl bg-slate-950/60 border border-slate-800 space-y-4">
          <!-- Chat bubbles injected here -->
        </div>

        <div id="feynman-error" class="hidden p-3 mb-3 bg-rose-500/10 text-rose-400 border border-rose-500/20 text-xs rounded-xl text-center"></div>

        <div class="flex gap-2">
          <textarea id="feynman-user-input" rows="2" placeholder="직접 이해한 내용을 설명해 보세요..." class="flex-1 bg-slate-900 border border-slate-700 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 resize-none text-slate-200"></textarea>
          <button onclick="sendFeynmanMessage()" id="feynman-send-btn" class="px-5 bg-indigo-600 hover:bg-indigo-500 text-white rounded-xl font-bold transition flex items-center justify-center shrink-0 h-12 self-end">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </button>
        </div>
      </div>
    </section>

    <!-- 3. AI CUSTOM QUIZ SECTION -->
    <section id="section-quiz" class="tab-content hidden bg-slate-800/40 border border-slate-700/60 rounded-2xl p-6 shadow-xl flex flex-col min-h-[500px]">
      <div class="border-b border-slate-700/60 pb-4 mb-5">
        <h2 class="text-lg font-bold text-indigo-400 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"/></svg>
          AI 자가 진단 맞춤 퀴즈 생성기
        </h2>
        <p class="text-xs text-slate-400">
          학습 성취도를 파악하기 위해 원하는 과목이나 개념을 입력하면 엄밀한 5지선다 문제 세트를 무한정 설계해 드립니다.
        </p>
      </div>

      <!-- Setup View -->
      <div id="quiz-setup" class="max-w-xl mx-auto w-full my-auto py-8 text-center flex flex-col items-center">
        <div class="w-16 h-16 bg-pink-500/10 border border-pink-500/20 rounded-2xl flex items-center justify-center text-pink-400 mb-5 animate-pulse">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"/></svg>
        </div>
        <h3 class="text-xl font-bold mb-2 text-slate-200">어떤 과목/주제 시험을 치르고 싶나요?</h3>
        <p class="text-sm text-slate-400 mb-6 leading-relaxed">
          원하는 주제를 입력하면 AI 분석관이 지식 구멍을 예리하게 검출할 5개의 객관식 문제집을 제조합니다.
        </p>

        <div class="flex flex-col sm:flex-row gap-2.5 w-full">
          <input type="text" id="quiz-subject-input" placeholder="예: 고교 지구과학 기하학, 르네상스 예술, 알고리즘 시간복잡도..." class="flex-1 bg-slate-900 border border-slate-700 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 placeholder-slate-500 text-slate-100"/>
          <button onclick="generateAIQuiz()" id="quiz-gen-btn" class="px-6 py-3 bg-indigo-600 hover:bg-indigo-500 text-white rounded-xl font-bold transition shadow-lg shadow-indigo-600/15 text-sm shrink-0">
            시험 시작
          </button>
        </div>
        <div id="quiz-setup-error" class="hidden mt-4 text-xs text-rose-400 bg-rose-500/10 border border-rose-500/20 px-3 py-2 rounded-xl"></div>
      </div>

      <!-- Active Quiz View -->
      <div id="quiz-active" class="hidden flex-1 flex flex-col lg:flex-row gap-6">
        <!-- Question & Options Card -->
        <div class="flex-1 bg-slate-900/60 border border-slate-800 rounded-xl p-5 flex flex-col justify-between">
          <div>
            <div class="flex justify-between items-center text-xs text-slate-400 mb-3 font-semibold">
              <span id="quiz-active-subject">주제: </span>
              <span id="quiz-progress-display" class="font-mono text-indigo-400">문항: 1 / 5</span>
            </div>
            <h4 id="quiz-question-text" class="text-base font-bold text-slate-100 mb-5 leading-relaxed">
              Q. 로딩중...
            </h4>

            <div id="quiz-options-container" class="space-y-2.5">
              <!-- Dynamically rendered options -->
            </div>
          </div>

          <!-- Actions -->
          <div class="mt-6 flex justify-end gap-3 border-t border-slate-800 pt-4">
            <button onclick="submitQuizAnswer()" id="quiz-submit-btn" disabled class="px-6 py-2.5 bg-indigo-600 hover:bg-indigo-500 disabled:opacity-50 text-white rounded-xl font-bold text-sm transition">
              제출 및 정답확인
            </button>
            <button onclick="nextQuizQuestion()" id="quiz-next-btn" class="hidden px-6 py-2.5 bg-emerald-600 hover:bg-emerald-500 text-white rounded-xl font-bold text-sm transition">
              다음 문제
            </button>
          </div>
        </div>

