    async function generateAIQuiz() {
      const subjectInput = document.getElementById('quiz-subject-input');
      quizSubject = subjectInput.value.trim();
      if (!quizSubject) return;

      const genBtn = document.getElementById('quiz-gen-btn');
      const errEl = document.getElementById('quiz-setup-error');
      
      genBtn.disabled = true;
      genBtn.textContent = 'AI 문제 제조 중...';
      errEl.classList.add('hidden');

      try {
        const systemPrompt = `당신은 사용자가 공부하고 검증할 수 있는 깊이 있고 엄밀한 5지선다(A,B,C,D,E) 학술 시험형 문제 출제위원입니다. 
사용자가 입력한 주제에 대해 5문항의 퀴즈를 엄선하여 정확한 JSON 형태로만 반환해야 합니다.`;

        const responseSchema = {
          type: "OBJECT",
          properties: {
            quizzes: {
              type: "ARRAY",
              description: "An array of 5 study questions based on the topic",
              items: {
                type: "OBJECT",
                properties: {
                  question: { type: "STRING", description: "The conceptual or calculated study question" },
                  options: {
                    type: "ARRAY",
                    description: "Exactly 5 realistic candidate answers in Korean",
                    items: { type: "STRING" }
                  },
                  correctIndex: { type: "INTEGER", description: "The 0-based index of the correct answer (0 to 4)" },
                  explanation: { type: "STRING", description: "Detailed, scholarly explanation in Korean clarifying why it's correct and why other choices are wrong." }
                },
                required: ["question", "options", "correctIndex", "explanation"]
              }
            }
          },
          required: ["quizzes"]
        };

        const payload = {
          contents: [{
            parts: [{ text: `주제 [${quizSubject}]에 관련한 학습 성취도 진단용 5지선다 객관식 퀴즈 5개를 만들어 줘. 학습에 도움이 되는 깊은 설명도 제공해야 해.` }]
          }],
          systemInstruction: {
            parts: [{ text: systemPrompt }]
          },
          generationConfig: {
            responseMimeType: "application/json",
            responseSchema: responseSchema
          }
        };

        const result = await callGeminiAPI(payload);
        const text = result.candidates?.[0]?.content?.parts?.[0]?.text;
        const parsed = JSON.parse(text);

        if (parsed.quizzes && parsed.quizzes.length > 0) {
          quizQuestions = parsed.quizzes;
          currentQuizIdx = 0;
          selectedQuizAnswer = null;
          isQuizAnswerChecked = false;
          quizScore = 0;

          document.getElementById('quiz-setup').classList.add('hidden');
          document.getElementById('quiz-completed').classList.add('hidden');
          document.getElementById('quiz-active').classList.remove('hidden');

          renderQuizQuestion();
        } else {
          throw new Error("Invalid structure returned");
        }
      } catch (err) {
        errEl.textContent = "퀴즈를 실시간으로 설계하는 도중 네트워크 장해가 발생했습니다. 다시 시작해 보세요.";
        errEl.classList.remove('hidden');
      } finally {
        genBtn.disabled = false;
        genBtn.textContent = '시험 시작';
      }
    }

