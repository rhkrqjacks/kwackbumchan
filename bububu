    // Custom fetch with exponential backoff retry
    async function fetchWithRetry(url, options, retries = 5, delay = 1000) {
      try {
        const response = await fetch(url, options);
        if (!response.ok) {
          if (response.status === 429 && retries > 0) {
            await new Promise(resolve => setTimeout(resolve, delay));
            return fetchWithRetry(url, options, retries - 1, delay * 2);
          }
          throw new Error(`API Request failed with status: ${response.status}`);
        }
        return await response.json();
      } catch (error) {
        if (retries > 0) {
          await new Promise(resolve => setTimeout(resolve, delay));
          return fetchWithRetry(url, options, retries - 1, delay * 2);
        }
        throw error;
      }
    }

    // =========================================================================
    // 1. POMODORO TIMER LOGIC (WITH AUDIO SYNTHESIZERS)
    // =========================================================================
    let pomoMinutes = 25;
    let pomoSeconds = 0;
    let pomoIsActive = false;
    let pomoInterval = null;
    let pomoMode = 'study'; // study, shortBreak, longBreak
    let pomoSoundType = 'none'; // none, white, binaural

    const pomoConfigs = {
      study: { time: 25, label: '집중 시간 🎯', class: 'border-rose-500 text-rose-400 bg-rose-500/10', circleColor: '#F43F5E' },
      shortBreak: { time: 5, label: '짧은 휴식 ☕', class: 'border-emerald-500 text-emerald-400 bg-emerald-500/10', circleColor: '#10B981' },
      longBreak: { time: 15, label: '긴 휴식 🍃', class: 'border-indigo-500 text-indigo-400 bg-indigo-500/10', circleColor: '#6366F1' }
    };

    let audioCtx = null;
    let noiseNode = null;
    let binauralNodes = [];

    function initAudio() {
      if (!audioCtx) {
        audioCtx = new (window.AudioContext || window.webkitAudioContext)();
      }
    }

    function playAlertBeep() {
      try {
        initAudio();
        const osc = audioCtx.createOscillator();
        const gain = audioCtx.createGain();
        osc.type = 'sine';
        osc.frequency.setValueAtTime(587.33, audioCtx.currentTime); // D5
        osc.frequency.setValueAtTime(880, audioCtx.currentTime + 0.15); // A5
        gain.gain.setValueAtTime(0.3, audioCtx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.4);
        osc.connect(gain);
        gain.connect(audioCtx.destination);
        osc.start();
        osc.stop(audioCtx.currentTime + 0.55);
      } catch(e) {}
    }

    function stopSynthesizedSounds() {
      if (noiseNode) {
        try { noiseNode.stop(); } catch(e){}
        noiseNode = null;
      }
      if (binauralNodes.length > 0) {
        binauralNodes.forEach(n => {
          try { n.stop(); } catch(e){}
        });
        binauralNodes = [];
      }
    }

    function applyFocusSound() {
      stopSynthesizedSounds();
      if (pomoSoundType === 'none' || !pomoIsActive) return;

      initAudio();
      if (audioCtx.state === 'suspended') {
        audioCtx.resume();
      }

      if (pomoSoundType === 'white') {
        const bufferSize = 2 * audioCtx.sampleRate;
        const noiseBuffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
        const output = noiseBuffer.getChannelData(0);
        
        let lastOut = 0.0;
        for (let i = 0; i < bufferSize; i++) {
          const white = Math.random() * 2 - 1;
          // Brownian low-frequency ambient rumble formula
          output[i] = (lastOut + (0.02 * white)) / 1.02;
          lastOut = output[i];
          output[i] *= 3.5;
        }

        const noise = audioCtx.createBufferSource();
        noise.buffer = noiseBuffer;
        noise.loop = true;

        const filter = audioCtx.createBiquadFilter();
        filter.type = 'lowpass';
        filter.frequency.value = 400; // Low frequency hum

        const gain = audioCtx.createGain();
        gain.gain.value = 0.45;

        noise.connect(filter);
        filter.connect(gain);
        gain.connect(audioCtx.destination);

        noise.start();
        noiseNode = noise;
      } else if (pomoSoundType === 'binaural') {
        const oscL = audioCtx.createOscillator();
        const oscR = audioCtx.createOscillator();
        const merger = audioCtx.createChannelMerger(2);
        const gain = audioCtx.createGain();

        oscL.type = 'sine';
        oscL.frequency.value = 120; // Carrier freq
        oscR.type = 'sine';
        oscR.frequency.value = 134; // 14Hz Alpha offset

        gain.gain.value = 0.08;

        const gainL = audioCtx.createGain();
        const gainR = audioCtx.createGain();
        oscL.connect(gainL);
        oscR.connect(gainR);

        gainL.connect(merger, 0, 0);
        gainR.connect(merger, 0, 1);
        merger.connect(gain);
        gain.connect(audioCtx.destination);

        oscL.start();
        oscR.start();

        binauralNodes = [oscL, oscR];
      }
    }

    function setFocusSound(type) {
      pomoSoundType = type;
      document.querySelectorAll('.sound-toggle-btn').forEach(btn => {
        btn.classList.remove('border-indigo-500', 'bg-indigo-500/10', 'text-indigo-400');
        btn.classList.add('border-slate-700', 'bg-slate-900/60', 'text-slate-400');
      });

      const activeBtn = document.getElementById(`sound-btn-${type}`);
      if (activeBtn) {
        activeBtn.classList.remove('border-slate-700', 'bg-slate-900/60', 'text-slate-400');
        activeBtn.classList.add('border-indigo-500', 'bg-indigo-500/10', 'text-indigo-400');
      }

      applyFocusSound();
    }

    function updatePomoDisplay() {
      const displayStr = `${pomoMinutes.toString().padStart(2, '0')}:${pomoSeconds.toString().padStart(2, '0')}`;
      document.getElementById('pomo-time-display').textContent = displayStr;

      // Progress bar formula: (TotalSecs - CurrentSecs) / TotalSecs
      const totalSecs = pomoConfigs[pomoMode].time * 60;
      const currentSecs = pomoMinutes * 60 + pomoSeconds;
      const percent = totalSecs > 0 ? ((totalSecs - currentSecs) / totalSecs) : 0;
      
      const maxOffset = 691.15; // 2 * PI * r (110)
      const offset = maxOffset * (1 - percent);
      
      const circleEl = document.getElementById('pomo-progress-circle');
      circleEl.style.strokeDashoffset = offset;
      circleEl.style.stroke = pomoConfigs[pomoMode].circleColor;
    }

    function setPomoMode(mode) {
      pomoIsActive = false;
      if (pomoInterval) clearInterval(pomoInterval);
      
      pomoMode = mode;
      pomoMinutes = pomoConfigs[mode].time;
      pomoSeconds = 0;

      // Reset Active Buttons
      document.querySelectorAll('.pomo-mode-btn').forEach(btn => {
        btn.classList.remove('bg-indigo-600', 'text-white');
        btn.classList.add('bg-slate-900', 'text-slate-400', 'hover:text-slate-200');
      });
      document.getElementById(`pomo-btn-${mode}`).classList.remove('bg-slate-900', 'text-slate-400');
      document.getElementById(`pomo-btn-${mode}`).classList.add('bg-indigo-600', 'text-white');

      // Update badge
      const badge = document.getElementById('pomo-mode-badge');
      badge.className = `px-4 py-1.5 rounded-full text-xs font-bold border tracking-wider uppercase ${pomoConfigs[mode].class}`;
      badge.textContent = pomoConfigs[mode].label;

      document.getElementById('pomo-status-sub').textContent = '대기 중';
      document.getElementById('pomo-play-text').textContent = '집중 시작';
      document.getElementById('pomo-play-icon').innerHTML = `<polygon points="5 3 19 12 5 21 5 3"/>`;

      stopSynthesizedSounds();
      updatePomoDisplay();
    }

    function togglePomoTimer() {
      initAudio();
      if (pomoIsActive) {
        // Pause
        pomoIsActive = false;
        if (pomoInterval) clearInterval(pomoInterval);
        document.getElementById('pomo-play-text').textContent = '다시 시작';
        document.getElementById('pomo-play-icon').innerHTML = `<polygon points="5 3 19 12 5 21 5 3"/>`;
        document.getElementById('pomo-status-sub').textContent = '일시 정지';
        stopSynthesizedSounds();
      } else {
        // Start
        pomoIsActive = true;
        document.getElementById('pomo-play-text').textContent = '일시정지';
        document.getElementById('pomo-play-icon').innerHTML = `<rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/>`;
        document.getElementById('pomo-status-sub').textContent = '집중 중...';
        
        applyFocusSound();

        pomoInterval = setInterval(() => {
          if (pomoSeconds === 0) {
            if (pomoMinutes === 0) {
              handleTimerComplete();
            } else {
              pomoMinutes--;
              pomoSeconds = 59;
            }
          } else {
            pomoSeconds--;
          }
          updatePomoDisplay();
        }, 1000);
      }
    }

    function resetPomoTimer() {
      pomoIsActive = false;
      if (pomoInterval) clearInterval(pomoInterval);
      pomoMinutes = pomoConfigs[pomoMode].time;
      pomoSeconds = 0;
      
      document.getElementById('pomo-play-text').textContent = '집중 시작';
      document.getElementById('pomo-play-icon').innerHTML = `<polygon points="5 3 19 12 5 21 5 3"/>`;
      document.getElementById('pomo-status-sub').textContent = '대기 중';
      
      stopSynthesizedSounds();
      updatePomoDisplay();
    }

    let studyHistory = [];

    function handleTimerComplete() {
      pomoIsActive = false;
      if (pomoInterval) clearInterval(pomoInterval);
      playAlertBeep();

      const targetInput = document.getElementById('pomo-target-input');
      const targetText = targetInput.value.trim() || '기록된 목표가 없습니다.';
      const now = new Date();
      const timestamp = `${now.getHours().toString().padStart(2, '0')}:${now.getMinutes().toString().padStart(2, '0')}`;

      studyHistory.unshift({
        mode: pomoMode,
        duration: `${pomoConfigs[pomoMode].time}분`,
        target: targetText,
        time: timestamp
      });

      renderStudyHistory();

      // Auto cycle
      if (pomoMode === 'study') {
        setPomoMode('shortBreak');
      } else {
        setPomoMode('study');
      }
      targetInput.value = '';
    }

    function renderStudyHistory() {
      const container = document.getElementById('pomo-logs-container');
      if (studyHistory.length === 0) {
        container.innerHTML = `
          <div class="h-full flex items-center justify-center text-slate-500 italic py-6">
            오늘 집중한 세션이 아직 없습니다. 파이팅!
          </div>
        `;
        return;
      }

      container.innerHTML = studyHistory.map(item => {
        const badgeClass = item.mode === 'study' ? 'bg-rose-500/20 text-rose-400' : 'bg-emerald-500/20 text-emerald-400';
        return `
          <div class="flex justify-between items-start border-b border-slate-800/80 pb-2 last:border-0 last:pb-0">
            <div>
              <span class="inline-block px-1.5 py-0.5 rounded text-[10px] font-bold mr-1.5 uppercase ${badgeClass}">
                ${item.mode === 'study' ? '집중' : '휴식'}
              </span>
              <span class="text-slate-300 font-medium">${item.target}</span>
            </div>
            <div class="text-right text-slate-500 shrink-0 ml-2">
              <div>${item.duration}</div>
              <div class="text-[10px]">${item.time}</div>
            </div>
          </div>
        `;
      }).join('');
    }

    // =========================================================================
    // 2. SOCRATES FEYNMAN AI TUTOR LOGIC
    // =========================================================================
    let feynmanTopic = '';
    let feynmanHistory = [];
    let feynmanLoading = false;

    const socraticSystemPrompt = `당신은 사용자의 메타인지와 학습 상태를 극대화하는 최고의 소크라테스식 학습 조력자(Socratic Tutor)입니다.
사용자가 특정 물리, 수학, 역사, 경제 등 어떤 공부 개념에 대해 배우기 시작하면, 사용자가 직접 설명하게 만드는 "파인만 학습법(Feynman Technique)"을 따릅니다.
절대로 먼저 정답을 줄줄이 알려주지 마십시오!

작동 규칙:
1. 사용자가 개념을 입력하면, 사용자의 수준을 자극하는 따뜻하면서도 도전적인 첫 질문을 가볍게 던지세요. ("예를 들어, 식물이 햇빛을 밥으로 바꾸는 과정을 어린아이에게 설명한다고 해볼까요? 광합성은 어떻게 시작하나요?")
2. 사용자가 설명을 적어내면, 그 설명에서 맞은 부분과 논리적으로 빠졌거나 틀린 부분을 부드럽게 분석해 줍니다.
3. 그 후, 사용자가 그 부분을 스스로 메우거나 유추할 수 있도록 다음 질문을 소크라테스 식으로 던지세요. (어려운 힌트나 비유를 활용)
4. 모든 문체는 상냥한 반말(또는 격려 가득한 존댓말)을 구사하되, 학문적인 명확성은 완벽히 유지하세요.
5. 짧고 대화하듯이 친절하게 대답하세요.`;

    async function startFeynmanSession() {
      const topicInput = document.getElementById('feynman-topic-input');
      feynmanTopic = topicInput.value.trim();
      if (!feynmanTopic) return;

      feynmanLoading = true;
      document.getElementById('feynman-start-btn').disabled = true;
      document.getElementById('feynman-error').classList.add('hidden');

      feynmanHistory = [];

      try {
        const payload = {
          contents: [{
            parts: [{ text: `내가 오늘 공부하려는 주제는 [${feynmanTopic}]야. 소크라테스식 질문으로 내가 스스로 설명하며 깊게 이해할 수 있게 첫 번째 질문을 던져줘!` }]
          }],
          systemInstruction: {
            parts: [{ text: socraticSystemPrompt }]
          }
        };

        const result = await callGeminiAPI(payload);
        const text = result.candidates?.[0]?.content?.parts?.[0]?.text || "오류가 발생했습니다. 다시 시도해주세요.";

        feynmanHistory.push({ role: 'model', text });
        
        // Render view
        document.getElementById('feynman-setup').classList.add('hidden');
        document.getElementById('feynman-chat-area').classList.remove('hidden');
        document.getElementById('feynman-reset-btn').classList.remove('hidden');
        document.getElementById('feynman-active-topic').textContent = `공부 주제: ${feynmanTopic}`;
        
        renderFeynmanMessages();
      } catch (err) {
        const errEl = document.getElementById('feynman-error');
        errEl.textContent = "AI 연결에 실패했습니다. API 키 구성을 확인하시거나 나중에 다시 시도해주세요.";
        errEl.classList.remove('hidden');
      } finally {
        feynmanLoading = false;
        document.getElementById('feynman-start-btn').disabled = false;
      }
    }

    async function sendFeynmanMessage() {
      const inputEl = document.getElementById('feynman-user-input');
      const userText = inputEl.value.trim();
      if (!userText || feynmanLoading) return;

      inputEl.value = '';
      feynmanHistory.push({ role: 'user', text: userText });
      renderFeynmanMessages();

      feynmanLoading = true;
      document.getElementById('feynman-send-btn').disabled = true;
      document.getElementById('feynman-error').classList.add('hidden');

      // Inject loader bubble
      const msgBox = document.getElementById('feynman-messages');
      const loader = document.createElement('div');
      loader.id = "feynman-chat-loader";
      loader.className = "flex items-center gap-2 mr-auto text-slate-400 text-xs py-2";
      loader.innerHTML = `
        <div class="w-2 h-2 bg-indigo-500 rounded-full animate-bounce" style="animation-delay: 0ms"></div>
        <div class="w-2 h-2 bg-indigo-500 rounded-full animate-bounce" style="animation-delay: 150ms"></div>
        <div class="w-2 h-2 bg-indigo-500 rounded-full animate-bounce" style="animation-delay: 300ms"></div>
        <span>선생님이 나의 설명을 분석하여 메타인지 지도를 그리는 중...</span>
      `;
      msgBox.appendChild(loader);
      msgBox.scrollTop = msgBox.scrollHeight;

      try {
        const formattedContents = feynmanHistory.map(msg => ({
          role: msg.role === 'model' ? 'model' : 'user',
          parts: [{ text: msg.text }]
        }));

        const payload = {
          contents: formattedContents,
          systemInstruction: {
            parts: [{ text: socraticSystemPrompt }]
          }
        };

        const result = await callGeminiAPI(payload);
        const text = result.candidates?.[0]?.content?.parts?.[0]?.text || "답변을 가져오지 못했습니다.";

        feynmanHistory.push({ role: 'model', text });
        renderFeynmanMessages();
      } catch (err) {
        document.getElementById('feynman-error').textContent = "메시지 발송에 실패했습니다. 다시 작성해 보세요.";
        document.getElementById('feynman-error').classList.remove('hidden');
      } finally {
        const loaderEl = document.getElementById('feynman-chat-loader');
        if (loaderEl) loaderEl.remove();
        feynmanLoading = false;
        document.getElementById('feynman-send-btn').disabled = false;
      }
    }

